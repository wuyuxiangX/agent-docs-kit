#!/usr/bin/env bash
#
# living-docs installer
#
# Usage:
#   ./setup                              # install for claude code (default), symlink mode
#   ./setup --host claude                # explicit host
#   ./setup --host cursor                # install for cursor
#   ./setup --host codex                 # install for codex CLI
#   ./setup --host opencode              # install for opencode
#   ./setup --copy                       # copy files instead of symlinking
#   ./setup --uninstall                  # remove from the chosen host
#   ./setup -h | --help                  # this message
#
# The skill source is `skills/living-docs/` (SKILL.md + scripts + assets/).
# It will be installed to:
#   claude    → ~/.claude/skills/living-docs
#   cursor    → ~/.cursor/skills/living-docs
#   codex     → ~/.codex/skills/living-docs
#   opencode  → ~/.opencode/skills/living-docs

set -euo pipefail

HOST="claude"
MODE="link"
ACTION="install"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST="${2:-}"
      shift 2 ;;
    --link)   MODE="link"; shift ;;
    --copy)   MODE="copy"; shift ;;
    --uninstall) ACTION="uninstall"; shift ;;
    -h|--help)
      sed -n '1,/^set -e/p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    *)
      echo "Unknown argument: $1" >&2
      echo "Run with --help for usage." >&2
      exit 2 ;;
  esac
done

# Resolve source directory (the directory containing this script + skills/)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SRC="$SCRIPT_DIR/skills/living-docs"

if [ ! -d "$SRC" ]; then
  echo "Error: source directory not found at $SRC" >&2
  echo "Run this script from the living-docs repo root." >&2
  exit 1
fi

# Map host → target directory
case "$HOST" in
  claude)   TARGET_BASE="$HOME/.claude/skills" ;;
  cursor)   TARGET_BASE="$HOME/.cursor/skills" ;;
  codex)    TARGET_BASE="$HOME/.codex/skills" ;;
  opencode) TARGET_BASE="$HOME/.opencode/skills" ;;
  *)
    echo "Error: unknown host '$HOST'" >&2
    echo "Supported hosts: claude, cursor, codex, opencode" >&2
    exit 2 ;;
esac

TARGET="$TARGET_BASE/living-docs"

# Detect Windows-like environment (symlinks unreliable) and downgrade to copy
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    if [ "$MODE" = "link" ]; then
      echo "Detected Windows-like environment — switching from --link to --copy"
      MODE="copy"
    fi ;;
esac

# Uninstall path
if [ "$ACTION" = "uninstall" ]; then
  if [ -e "$TARGET" ] || [ -L "$TARGET" ]; then
    echo "Removing $TARGET"
    rm -rf "$TARGET"
    echo "Uninstalled living-docs from $HOST."
  else
    echo "Nothing to remove at $TARGET"
  fi
  exit 0
fi

# Install path
mkdir -p "$TARGET_BASE"

# If target already exists, prompt before overwriting
if [ -e "$TARGET" ] || [ -L "$TARGET" ]; then
  echo "Existing install found at $TARGET"
  printf "Overwrite? (y/N) "
  read -r REPLY
  case "$REPLY" in
    [yY]|[yY][eE][sS]) rm -rf "$TARGET" ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

# Install
if [ "$MODE" = "link" ]; then
  ln -s "$SRC" "$TARGET"
  echo "Symlinked $SRC → $TARGET"
else
  cp -R "$SRC" "$TARGET"
  echo "Copied $SRC → $TARGET"
fi

# Verify
if [ -f "$TARGET/SKILL.md" ]; then
  echo
  echo "✓ living-docs installed for $HOST"
  echo "  Path: $TARGET"
  echo "  Mode: $MODE"
  echo
  echo "Next steps:"
  echo "  1. In any project root, initialize the docs system:"
  echo "       python3 \"$TARGET/init.py\""
  echo "  2. Add a domain and a change:"
  echo "       python3 \"$TARGET/new_domain.py\" <domain>"
  echo "       python3 \"$TARGET/new_change.py\" <domain> <topic-slug>"
  echo "  3. Before committing docs changes, run the gate:"
  echo "       python3 \"$TARGET/check_docs.py\""
else
  echo "Error: install completed but SKILL.md not found at $TARGET/SKILL.md" >&2
  exit 1
fi
